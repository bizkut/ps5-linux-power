#!/bin/sh
set -u

CONFIG="${PS5GOV_CONFIG:-/etc/ps5-linux-power/ps5gov.conf}"
SERVICE="${PS5GOV_SERVICE:-ps5gov.service}"
RUNNER="${PS5GOV_RUNNER:-/usr/local/lib/ps5-linux-power/governors/run-governors.sh}"
TOOLS_DIR="${PS5GOV_TOOLS_DIR:-/usr/local/lib/ps5-linux-power}"
CPU_CTL="$TOOLS_DIR/ps5_cpu"
GPU_CTL="$TOOLS_DIR/ps5_gpu"
BOOST_CTL="$TOOLS_DIR/ps5_boost"
BOOST_STATE="/run/ps5-power.boost"
PERFORMANCE_STATE="${PS5GOV_PERFORMANCE_STATE:-/run/ps5-power.performance}"
FAN_STATE="/run/ps5-power.fan"
CPU_STATE="/run/ps5-power.cpu"
GPU_STATE="/run/ps5-power.gpu"

FAN_SERVICE="ps5fan.service"

usage() {
	echo "usage: ps5govctl profile <auto|powersave|quiet|balanced|performance>|performance <on|off|status>|config|sensors|status|reload|restart|restore|stop-boost" >&2
	exit 2
}

need_root() {
	[ "$(id -u)" -eq 0 ] || {
		echo "ps5govctl: must run as root" >&2
		exit 1
	}
}

reload_or_restart() {
	systemctl reload "$SERVICE" 2>/dev/null || systemctl restart "$SERVICE"
}

write_profile() {
	profile="$1"
	case "$profile" in
	auto|powersave|quiet|balanced|performance) ;;
	*) usage ;;
	esac

	need_root
	mkdir -p "$(dirname "$CONFIG")"
	if [ -f "$CONFIG" ] && grep -q '^PROFILE=' "$CONFIG"; then
		tmp="${CONFIG}.tmp"
		sed "s/^PROFILE=.*/PROFILE=$profile/" "$CONFIG" > "$tmp"
		mv "$tmp" "$CONFIG"
	else
		printf 'PROFILE=%s\n' "$profile" >> "$CONFIG"
	fi
	reload_or_restart
}

show_sensors() {
	service_state=$(systemctl is-active "$SERVICE" 2>/dev/null || true)
	fan_state=$(systemctl is-active "$FAN_SERVICE" 2>/dev/null || true)
	[ -n "$service_state" ] || service_state=unknown
	[ -n "$fan_state" ] || fan_state=unknown
	printf 'service=%s\n' "$service_state"
	if [ -r "$FAN_STATE" ]; then
		sed 's/^/fan_state_/' "$FAN_STATE"
	else
		printf 'fan_state=unknown\n'
	fi
	if [ -r "$CPU_STATE" ]; then
		sed 's/^/cpu_state_/' "$CPU_STATE"
	else
		printf 'cpu_state=unknown\n'
	fi
	if [ -r "$GPU_STATE" ]; then
		sed 's/^/gpu_state_/' "$GPU_STATE"
	else
		printf 'gpu_state=unknown\n'
	fi
	printf 'fan_service=%s\n' "$fan_state"
	[ -x "$BOOST_CTL" ] && "$BOOST_CTL" status 2>/dev/null || {
		if [ -r "$BOOST_STATE" ]; then
			printf 'boost_state=%s\n' "$(cat "$BOOST_STATE")"
		else
			printf 'boost_state=0x0\n'
		fi
	}
	[ -x "$CPU_CTL" ] && "$CPU_CTL" get 0 2>/dev/null || true
	[ -x "$GPU_CTL" ] && "$GPU_CTL" get 2>/dev/null || true
	PS5GOV_CONFIG="$CONFIG" "$RUNNER" --print-config 2>/dev/null || true

	for temp_input in /sys/class/hwmon/hwmon*/temp*_input; do
		[ -r "$temp_input" ] || continue
		hwmon_dir=${temp_input%/*}
		name=unknown
		[ -r "$hwmon_dir/name" ] && name=$(cat "$hwmon_dir/name")
		temp=$(awk '{printf "%.1f C", $1 / 1000}' "$temp_input")
		printf 'sensor=%s name=%s temp=%s\n' "$temp_input" "$name" "$temp"
	done
}

restore_defaults() {
	need_root
	systemctl stop "$SERVICE" 2>/dev/null || true
	[ -x "$BOOST_CTL" ] && "$BOOST_CTL" off
	[ -x "$CPU_CTL" ] && "$CPU_CTL" set 0xff 0
	[ -x "$GPU_CTL" ] && "$GPU_CTL" reset
}

stop_boost() {
	need_root
	[ -x "$BOOST_CTL" ] || {
		echo "ps5govctl: missing $BOOST_CTL (run 'make install')" >&2
		exit 1
	}
	"$BOOST_CTL" off
}

performance_mode() {
	[ "$#" -eq 1 ] || usage
	case "$1" in
	on)
		need_root
		mkdir -p "$(dirname "$PERFORMANCE_STATE")"
		printf 'on\n' > "$PERFORMANCE_STATE"
		reload_or_restart
		;;
	off)
		need_root
		mkdir -p "$(dirname "$PERFORMANCE_STATE")"
		printf 'off\n' > "$PERFORMANCE_STATE"
		reload_or_restart
		;;
	status)
		if [ -r "$PERFORMANCE_STATE" ]; then
			case "$(cat "$PERFORMANCE_STATE" 2>/dev/null)" in
			1|on|true|performance) printf 'performance_mode=on\n' ;;
			*) printf 'performance_mode=off\n' ;;
			esac
		else
			printf 'performance_mode=off\n'
		fi
		;;
	*) usage ;;
	esac
}

[ "$#" -ge 1 ] || usage

case "$1" in
profile)
	[ "$#" -eq 2 ] || usage
	write_profile "$2"
	;;
performance)
	shift
	performance_mode "$@"
	;;
status)
	systemctl status "$SERVICE"
	;;
config)
	PS5GOV_CONFIG="$CONFIG" "$RUNNER" --print-config
	;;
sensors)
	show_sensors
	;;
reload)
	need_root
	systemctl reload "$SERVICE"
	;;
restart)
	need_root
	systemctl restart "$SERVICE"
	;;
restore)
	restore_defaults
	;;
stop-boost)
	stop_boost
	;;
*)
	usage
	;;
esac
